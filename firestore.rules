rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Listings: public read, no client writes
    match /listings/{listingId} {
      allow read: if true;
      allow write: if false;
    }

    // Leads: no client access (all through admin SDK API routes)
    match /leads/{leadId} {
      allow read, write: if false;
    }

    // Follow-ups: no client access
    match /follow_ups/{followUpId} {
      allow read, write: if false;
    }

    // Voice calls: no client access
    match /voice_calls/{callId} {
      allow read, write: if false;
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
